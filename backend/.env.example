APP_NAME=Mapathon API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

API_V1_PREFIX=/api/v1

# AvalAI / OpenAI-compatible API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.avalai.ir/v1
LLM_DEFAULT_MODEL=gpt-4o-mini

# Neshan web service key
NESHAN_API_KEY=
NESHAN_BASE_URL=https://api.neshan.org
NESHAN_TIMEOUT_SECONDS=30

# Neshan endpoint paths
NESHAN_SEARCH_PATH=/v1/search
NESHAN_GEOCODING_PATH=/v4/geocoding
NESHAN_REVERSE_GEOCODING_PATH=/v5/reverse
NESHAN_ROUTING_PATH=/v4/direction
NESHAN_NO_TRAFFIC_ROUTING_PATH=/v4/direction/no-traffic
NESHAN_HISTORICAL_ROUTING_PATH=/v4/direction/historical
NESHAN_TYPICAL_ROUTING_PATH=/v4/direction/typical
NESHAN_PEDESTRIAN_ROUTING_PATH=/v4/direction/pedestrian
NESHAN_TSP_PATH=/v3/trip
NESHAN_DISTANCE_MATRIX_PATH=/v1/distance-matrix
NESHAN_ISOCHRONE_PATH=/v1/isochrone
NESHAN_MAP_MATCHING_PATH=/v1/map-matching

DEFAULT_COUNTRY=ایران
DEFAULT_CITY=
DEFAULT_LATITUDE=32.4279
DEFAULT_LONGITUDE=53.6880
DEFAULT_ZOOM=5

CORS_ORIGINS=http://localhost:3000,https://mapathon.ir,https://www.mapathon.ir

LOG_LEVEL=INFO
INCLUDE_AGENT_DEBUG=false
